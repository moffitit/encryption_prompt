<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="MailApp">

  <Id>fcc518cb-d591-4006-9dc6-73ad7fd8f005</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Your Organisation</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Encrypt Prompt"/>
  <Description DefaultValue="Prompts you to encrypt this email with Microsoft Purview OME before sending."/>
  <IconUrl DefaultValue="https://localhost:3000/assets/icon-80.png"/>
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/assets/icon-128.png"/>
  <SupportUrl DefaultValue="https://localhost:3000/support"/>

  <AppDomains>
    <AppDomain>https://localhost:3000</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://localhost:3000/commands.html"/>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>

  <!-- V1_0: ribbon button only -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="v10_Commands_Url"/>

          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgComposeGroup">
                <Label resid="v10_GroupLabel"/>
                <Control xsi:type="Button" id="encryptDialogButton">
                  <Label resid="v10_DialogButton_Label"/>
                  <Supertip>
                    <Title resid="v10_DialogButton_Label"/>
                    <Description resid="v10_DialogButton_Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="v10_Icon_16x16"/>
                    <bt:Image size="32" resid="v10_Icon_32x32"/>
                    <bt:Image size="80" resid="v10_Icon_80x80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>openEncryptDialog</FunctionName>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="v10_Icon_16x16" DefaultValue="https://localhost:3000/assets/icon-16.png"/>
        <bt:Image id="v10_Icon_32x32" DefaultValue="https://localhost:3000/assets/icon-32.png"/>
        <bt:Image id="v10_Icon_80x80" DefaultValue="https://localhost:3000/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="v10_Commands_Url" DefaultValue="https://localhost:3000/commands.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="v10_GroupLabel" DefaultValue="Encryption"/>
        <bt:String id="v10_DialogButton_Label" DefaultValue="Encrypt Prompt"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="v10_DialogButton_Tooltip" DefaultValue="Prompt to encrypt this email with Microsoft Purview OME."/>
      </bt:LongStrings>
    </Resources>

    <!-- V1_1: Smart Alerts OnMessageSend -->
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">
      <Requirements>
        <bt:Sets DefaultMinVersion="1.12">
          <bt:Set Name="Mailbox"/>
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">
          <DesktopFormFactor>
            <FunctionFile resid="v11_Commands_Url"/>

            <ExtensionPoint xsi:type="MessageComposeCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgComposeGroup11">
                  <Label resid="v11_GroupLabel"/>
                  <Control xsi:type="Button" id="encryptDialogButton11">
                    <Label resid="v11_DialogButton_Label"/>
                    <Supertip>
                      <Title resid="v11_DialogButton_Label"/>
                      <Description resid="v11_DialogButton_Tooltip"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="v11_Icon_16x16"/>
                      <bt:Image size="32" resid="v11_Icon_32x32"/>
                      <bt:Image size="80" resid="v11_Icon_80x80"/>
                    </Icon>
                    <Action xsi:type="ExecuteFunction">
                      <FunctionName>openEncryptDialog</FunctionName>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>

            <ExtensionPoint xsi:type="LaunchEvent">
              <LaunchEvents>
                <LaunchEvent Type="OnMessageSend" FunctionName="onMessageSendHandler" SendMode="PromptUser"/>
              </LaunchEvents>
              <SourceLocation resid="v11_LaunchEvent_Url"/>
            </ExtensionPoint>

          </DesktopFormFactor>
        </Host>
      </Hosts>

      <Resources>
        <bt:Images>
          <bt:Image id="v11_Icon_16x16" DefaultValue="https://localhost:3000/assets/icon-16.png"/>
          <bt:Image id="v11_Icon_32x32" DefaultValue="https://localhost:3000/assets/icon-32.png"/>
          <bt:Image id="v11_Icon_80x80" DefaultValue="https://localhost:3000/assets/icon-80.png"/>
        </bt:Images>
        <bt:Urls>
          <bt:Url id="v11_Commands_Url" DefaultValue="https://localhost:3000/commands.html"/>
          <bt:Url id="v11_LaunchEvent_Url" DefaultValue="https://localhost:3000/launchevent.js"/>
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="v11_GroupLabel" DefaultValue="Encryption"/>
          <bt:String id="v11_DialogButton_Label" DefaultValue="Encrypt Prompt"/>
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="v11_DialogButton_Tooltip" DefaultValue="Prompt to encrypt this email with Microsoft Purview OME."/>
        </bt:LongStrings>
      </Resources>

    </VersionOverrides>
  </VersionOverrides>
</OfficeApp>
